# kiro2chat 环境变量

LOG_LEVEL=info

# ---- Telegram ----
TG_BOT_TOKEN=

# ---- Lark/Feishu ----
LARK_APP_ID=
LARK_APP_SECRET=
LARK_DOMAIN=feishu          # feishu (国内) | lark (国际版)

# ---- Web Chat ----
# WEB_HOST=127.0.0.1       # 监听地址
# WEB_PORT=8080             # 监听端口

# ---- ACP ----
# KIRO_CLI_PATH=kiro-cli    # kiro-cli 路径
# WORKSPACE_MODE=per_chat   # per_chat (隔离) | fixed (共享目录)
# WORKING_DIR=              # 工作目录 (fixed 模式)
# IDLE_TIMEOUT=300          # 空闲超时秒数 (0=不超时)
